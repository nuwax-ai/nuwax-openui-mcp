{
  "name": "@nuwax-ai/openui-mcp",
  "version": "0.1.0",
  "description": "OpenUI over MCP for Nuwax, with inline and sidecar rendering contracts.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nuwax-ai/nuwax-openui-mcp.git"
  },
  "homepage": "https://github.com/nuwax-ai/nuwax-openui-mcp#readme",
  "bugs": {
    "url": "https://github.com/nuwax-ai/nuwax-openui-mcp/issues"
  },
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./contracts": {
      "types": "./dist/server/contracts.d.ts",
      "import": "./dist/server/contracts.js"
    }
  },
  "bin": {
    "nuwax-openui-mcp": "dist/server/stdio.js",
    "nuwax-openui-mcp-http": "dist/server/http.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm build:server && pnpm build:web",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "dev:http": "tsx watch src/http.ts",
    "dev:stdio": "tsx src/stdio.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "start": "node dist/server/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "prepublishOnly": "pnpm verify"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@openuidev/react-lang": "0.2.8",
    "@openuidev/react-ui": "0.12.1",
    "dotenv": "17.4.2",
    "express": "5.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "4.1.12",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/express": "5.0.5",
    "@types/node": "24.10.1",
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "5.1.1",
    "eslint": "9.39.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "prettier": "3.7.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.1",
    "vite": "7.2.6",
    "vitest": "4.0.15"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.3"
}
